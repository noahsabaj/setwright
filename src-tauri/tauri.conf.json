{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Setwright",
  "version": "0.1.0",
  "identifier": "org.setwright.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost blob: data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Setwright",
        "width": 1440,
        "height": 920,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Write papers, not TeX.",
    "longDescription": "A local-first visual editor for standard LaTeX research papers.",
    "copyright": "Copyright Setwright contributors",
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "createUpdaterArtifacts": false
  }
}
